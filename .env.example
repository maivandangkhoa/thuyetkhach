# Port the game backend listens on.
PORT=8788

# Groq cloud models (OpenAI-compatible). The game's whole model chain runs on
# Groq. Get a key at https://console.groq.com
GROQ_API_KEY=

# Model the game uses. Use a groq:-prefixed id — without a local Ollama, a
# non-groq id makes every request burn one failed round-trip first.
GAME_MODEL=groq:qwen/qwen3-32b

# Optional: only needed if GAME_MODEL is a local (non-groq:) model.
# OLLAMA_HOST=http://localhost:11434

# Where per-scenario play/win counters are persisted. Point this OUTSIDE the
# app dir so deploy.sh's `rsync --delete` never wipes it.
# STATS_FILE=/home/ubuntu/game-data/game-stats.json

# Absolute origin used in OG/share URLs.
# PUBLIC_ORIGIN=https://game.fechtin.com

# Firebase web config (CLIENT-side, bundled into the frontend at build time —
# these are PUBLIC values, not secrets). Needed for optional Google login +
# cross-device progress sync. Leave empty to disable login (the game still
# works in anonymous localStorage mode).
# NOTE: baked into the bundle by `vite build`, so they must exist wherever the
# build runs (incl. the VM during deploy.sh), not just at server runtime.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
